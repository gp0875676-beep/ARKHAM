# ============================================================
# ARC REACTOR — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- Python / Runtime ----
PYTHON_VERSION=3.11.9
ENV=production
LOG_LEVEL=INFO

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated list of Telegram User IDs allowed to run /addwhale, /removewhale, etc.
TELEGRAM_ADMIN_IDS=

# ---- Database (Render provides DATABASE_URL automatically) ----
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Scanner global behavior ----
POLL_INTERVAL_SECONDS=30
MIN_USD_THRESHOLD=10000.0
DEDUP_WINDOW_SECONDS=600
MAX_WORKERS_PER_CHAIN=4
BACKOFF_BASE_SECONDS=1.5
BACKOFF_MAX_SECONDS=60
BACKOFF_RETRIES=5
PER_PROVIDER_RPM=300

# ---- Price oracle (non-Binance) ----
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
PRICE_CACHE_TTL_SECONDS=60

# ---- Ethereum ----
ETH_ENABLED=true
ETH_RPC_URL=
ETH_ETHERSCAN_API_KEY=
ETH_ETHERSCAN_BASE_URL=https://api.etherscan.io/api
ETH_EXPLORER_TX_URL=https://etherscan.io/tx
WHALE_WALLETS_ETH=0xAb5801a7D398351b8bE11C439e05C5B3259aeC9B,0x71b8db1f1e6d14c6d4f8c8b0b0c0c0b0b0b0b0b0

# ---- BNB Smart Chain ----
BSC_ENABLED=false
BSC_RPC_URL=
BSC_BSCSCAN_API_KEY=
BSC_BSCSCAN_BASE_URL=https://api.bscscan.com/api
BSC_EXPLORER_TX_URL=https://bscscan.com/tx
WHALE_WALLETS_BSC=

# ---- Polygon ----
POLYGON_ENABLED=false
POLYGON_RPC_URL=
POLYGON_POLYGONSCAN_API_KEY=
POLYGON_POLYGONSCAN_BASE_URL=https://api.polygonscan.com/api
POLYGON_EXPLORER_TX_URL=https://polygonscan.com/tx
WHALE_WALLETS_POLYGON=

# ---- Arbitrum ----
ARBITRUM_ENABLED=false
ARBITRUM_RPC_URL=
ARBITRUM_ARBISCAN_API_KEY=
ARBITRUM_ARBISCAN_BASE_URL=https://api.arbiscan.io/api
ARBITRUM_EXPLORER_TX_URL=https://arbiscan.io/tx
WHALE_WALLETS_ARBITRUM=

# ---- Exchange Directory (Phase 2) ----
# JSON format: {"chain": {"address": "Exchange Name"}}
EXCHANGE_WALLETS_JSON={"ethereum": {"0x28C6c06298d514Db0899Cf07F97a4C1A8e7b2b1B": "Binance"}, "bsc": {"0x8894E0a0c962CB723c1976a4421c95949bE2D4E3": "Binance"}, "polygon": {"0x3527917576EB9831d61011B7CFA6943782379441": "Binance"}}

# ---- Clustering (Phase 3) ----
CLUSTER_MIN_COMMON_FUNDING_TXS=2
CLUSTER_MIN_COTX_COUNT=3
CLUSTER_TIMING_WINDOW_SECONDS=120

# ---- Scoring weights (Phase 4) — must sum to 1.0 ----
SCORE_WEIGHT_USD=0.45
SCORE_WEIGHT_WALLET_HISTORY=0.20
SCORE_WEIGHT_CLUSTER_SIZE=0.15
SCORE_WEIGHT_EXCHANGE_PROXIMITY=0.20

# ---- Dashboard (Phase 6, optional) ----
DASHBOARD_ENABLED=false
DASHBOARD_PORT=10000
